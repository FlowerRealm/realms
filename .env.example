# Copy this file to `.env` before local or Docker-based startup.
# Do not commit real secrets.

# MySQL bootstrap for docker compose.
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=realms

# Optional host mapping for docker compose MySQL.
# MYSQL_HOST_PORT=3306
# MYSQL_BIND_IP=0.0.0.0

# Minimal Realms startup env surface.
REALMS_ENV=prod
REALMS_ADDR=:8080
SESSION_SECRET=

# Database startup config.
REALMS_DB_DSN=root:root@tcp(127.0.0.1:3306)/realms?parseTime=true&charset=utf8mb4&collation=utf8mb4_unicode_ci&time_zone=%27%2B00%3A00%27
REALMS_DB_DSN_DOCKER=root:root@tcp(mysql:3306)/realms?parseTime=true&charset=utf8mb4&collation=utf8mb4_unicode_ci&time_zone=%27%2B00%3A00%27
# REALMS_DB_DRIVER=sqlite
# REALMS_SQLITE_PATH=./data/realms.db?_busy_timeout=30000

# Optional admin/system auth.
REALMS_ADMIN_API_KEY=
REALMS_SUBSCRIPTION_ORDER_WEBHOOK_SECRET=

# Optional compact gateway.
REALMS_COMPACT_GATEWAY_BASE_URL=
REALMS_COMPACT_GATEWAY_KEY=

# Optional CLI runner for channel test.
REALMS_CHANNEL_TEST_CLI_RUNNER_URL=http://127.0.0.1:3100
